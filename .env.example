# Copy this file to .env and fill in real values.
# NEVER commit the real .env file to GitHub.

# Comma-separated list of origins allowed to call this API.
# Use * only for local testing — lock this down before going live.
ALLOWED_ORIGINS=http://localhost:5500,https://your-portfolio-domain.com

# Gmail account #1 (required)
# GMAIL_PASS must be a 16-character Gmail "App Password", not your real password.
# Generate one at: https://myaccount.google.com/apppasswords
GMAIL_USER_1=your.first.account@gmail.com
GMAIL_PASS_1=xxxxxxxxxxxxxxxx

# Gmail account #2 (optional — used if account #1 fails/hits its daily cap)
GMAIL_USER_2=your.second.account@gmail.com
GMAIL_PASS_2=xxxxxxxxxxxxxxxx

# Gmail account #3 (optional)
GMAIL_USER_3=your.third.account@gmail.com
GMAIL_PASS_3=xxxxxxxxxxxxxxxx

# Where contact form messages should actually be delivered.
# Defaults to GMAIL_USER_1 if not set.
CONTACT_TO_EMAIL=your.inbox@gmail.com

# Port the server listens on (Render/Railway set this automatically)
PORT=3001
